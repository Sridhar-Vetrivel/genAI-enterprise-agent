# Psiog Kendra - configuration
#
# Copy to .env at the repo root and edit. .env is gitignored; this file is not.
#   cp deploy/.env.example .env
#
# Every value below has a working default in psiog_kendra/config.py. Nothing is
# hardcoded anywhere else, so any of these can be changed without touching code.

# =============================================================================
# LLM INFERENCE  --  local Ollama, zero cost
# =============================================================================
# OpenRouter is NOT provisioned, so all inference is local. Two tiers:
#   AI_MODEL_COMPLEX -> routing, cross-domain synthesis, grounding judge  (hard)
#   AI_MODEL_SIMPLE  -> phrasing one already-retrieved record             (simple)
#
# To move to OpenRouter later, change these two values (and point OLLAMA_HOST at the
# gateway). No code change is required.
#   AI_MODEL_COMPLEX=google/gemini-2.5-flash
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_PATH=/api/chat
OLLAMA_EMBED_PATH=/api/embed

AI_MODEL_COMPLEX=gemma3:4b
AI_MODEL_SIMPLE=gemma3:1b
# gemma3 cannot embed; nomic-embed-text is the local embedding model (768-dim).
AI_EMBED_MODEL=nomic-embed-text

AI_TEMPERATURE=0.0
AI_TIMEOUT_SECONDS=180
AI_RETRIES=2

# Context window. Smaller = smaller KV cache = less RAM needed to load the model.
AI_NUM_CTX=4096

# gemma3:4b needs ~4 GiB of FREE RAM to load. On a loaded machine Ollama refuses it with
# "model requires more system memory". With this on, such a call degrades to
# AI_MODEL_SIMPLE instead of failing the query; the downgrade is logged, never silent.
# Set to false to make an unloadable complex model a hard error instead.
AI_FALLBACK_ON_OOM=true

# Reserved for when OpenRouter is provisioned. Leave blank until then.
OPENROUTER_API_KEY=

# =============================================================================
# AGENTFIELD CONTROL PLANE
# =============================================================================
AGENTFIELD_SERVER=http://localhost:8080
AGENTFIELD_EXECUTE_PATH=/api/v1/execute

# =============================================================================
# AGENT NODE IDS  --  1 coordinator + 4 specialists + 1 QA judge
# =============================================================================
NODE_COORDINATOR=coordinator
NODE_DATA_AGENT=data-agent
NODE_DEVOPS_AGENT=devops-agent
NODE_CRM_AGENT=crm-agent
NODE_DOCS_AGENT=docs-agent
NODE_JUDGE_AGENT=judge-agent

# =============================================================================
# AGENT NODE PORTS
# -----------------------------------------------------------------------------
# Each node serves its own FastAPI app. AgentField defaults all of them to 8001,
# so when `make agents` starts the five together, one wins the socket and the rest
# die with "address already in use" -- but only AFTER registering with the control
# plane. The fleet then lists 5 nodes while 4 are dead, and every call routed to
# them hangs. One port per node.
# =============================================================================
PORT_COORDINATOR=8001
PORT_DATA_AGENT=8002
PORT_DEVOPS_AGENT=8003
PORT_CRM_AGENT=8004
PORT_DOCS_AGENT=8005

# The host the CONTROL PLANE dials to reach a node. The nodes run on the host; the
# control plane runs in Docker, where "localhost" means the container itself -- a node
# registering http://localhost:8002 sends every call to the container's own empty port
# ("connection refused"). Set to `localhost` only if you run the control plane outside
# Docker.
AGENT_CALLBACK_HOST=host.docker.internal

# =============================================================================
# DATA SOURCES
# =============================================================================
# true  -> specialists read the synthetic fixtures in data/mock/ (capstone demo).
# false -> specialists call the live REST APIs below; credentials then required.
USE_MOCK_SOURCES=true

# --- Databricks (data-platform domain) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_RUNS_PATH=/api/2.1/jobs/runs/list
DATABRICKS_PAGE_SIZE=25

# --- GitHub Actions / Azure DevOps (devops domain) ---
GITHUB_API=https://api.github.com
GITHUB_REPO=psiog/platform
GITHUB_TOKEN=
GITHUB_RUNS_PATH=/repos/{repo}/actions/runs
GITHUB_PAGE_SIZE=25

# --- CRM (crm domain) ---
CRM_API_BASE=
CRM_API_KEY=

SOURCE_TIMEOUT_SECONDS=30
# How many source records a specialist puts in front of the LLM.
MAX_RECORDS_IN_PROMPT=5

# =============================================================================
# RAG  --  semantic search over internal docs (docs domain)
# =============================================================================
RAG_TOP_K=5
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=150
# Chunks scoring below this cosine similarity are dropped rather than cited.
RAG_MIN_SCORE=0.25

# =============================================================================
# QA TARGETS  --  graded by the RFP
# =============================================================================
QA_TARGET_ROUTING_ACCURACY=100
QA_TARGET_HALLUCINATION_RATE=10

# How much raw source content the Judge Agent sees when grading one answer. This is the
# single biggest cost driver in `make qa` — a full run is ~60 local LLM calls. 5000 chars
# comfortably covers the cited records; raise it if the judge starts reporting that it
# cannot find a cited source.
QA_JUDGE_SOURCE_CHAR_LIMIT=5000

# How much of a "claim" must overlap the answer's own words before the judge is allowed to
# score it. Left to itself, gemma3 enumerates fields of the RAW SOURCE the answer never
# mentioned — "The branch is main", "The actor is priya.n" — which are trivially grounded
# (it copied them out of the source it is grading against) and quietly drag the hallucination
# rate DOWN by padding the denominator with free passes. 0.5 = at least half the claim's
# content words must appear in the answer. Raise it to be stricter about what counts as a
# claim the answer actually made.
QA_JUDGE_CLAIM_OVERLAP=0.5

# Hard stop per test query, in seconds. A cross-domain query is 5-7 SEQUENTIAL LLM calls --
# the coordinator cannot synthesise until every specialist has answered, and the judge cannot
# grade until the answer exists -- and on local CPU inference (gemma3:4b under Ollama, no GPU)
# that can run past 15 minutes. Without a limit, one stalled query hangs the whole suite.
#
# A timed-out query is RECORDED as timed out, never silently skipped: a missing result and a
# failed result must not look the same in the report.
#
# This is a deployment constraint, not a design one. OpenRouter is not provisioned, so the
# zero-cost local fallback is carrying the whole build; on a hosted endpoint each call is
# sub-second and these queries return in seconds. Set 0 to disable the limit.
QA_QUERY_TIMEOUT_SECONDS=900

# =============================================================================
# PATHS  --  relative paths are anchored at the repo root
# =============================================================================
DOCS_DIR=data/docs
MOCK_DIR=data/mock
INDEX_PATH=data/index/vectors.json
QA_REPORT_PATH=data/qa_report.json
# Per-query evidence pages for the mid-term Evidence Pack (`make evidence`).
EVIDENCE_DIR=docs/qa
