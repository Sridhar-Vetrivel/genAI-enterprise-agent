    {
      "id": "dl0",
      "type": "text",
      "x": 88,
      "y": 278,
      "width": 1140,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "text": "\u2460 HTTP Trigger receives query  \u2192  starts orchestration instance",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "\u2460 HTTP Trigger receives query  \u2192  starts orchestration instance",
      "lineHeight": 1.3
    },
    {
      "id": "dl1",
      "type": "text",
      "x": 88,
      "y": 310,
      "width": 1140,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "text": "\u2461 intent = await context.call_activity('classify_intent', query)   \u2192   LangChain LLMChain \u2192 Gemini 2.5 Flash \u2192 {\"domains\": [\"data\",\"docs\"]}",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "\u2461 intent = await context.call_activity('classify_intent', query)   \u2192   LangChain LLMChain \u2192 Gemini 2.5 Flash \u2192 {\"domains\": [\"data\",\"docs\"]}",
      "lineHeight": 1.3
    },
    {
      "id": "dl2",
      "type": "text",
      "x": 88,
      "y": 342,
      "width": 1140,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "text": "\u2462 tasks = [context.call_activity(domain, query) for domain in intent[\"domains\"]]",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "\u2462 tasks = [context.call_activity(domain, query) for domain in intent[\"domains\"]]",
      "lineHeight": 1.3
    },
    {
      "id": "dl3",
      "type": "text",
      "x": 88,
      "y": 374,
      "width": 1140,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "text": "\u2463 results = yield context.task_all(tasks)   \u2192   parallel fan-out to Activity Functions",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "\u2463 results = yield context.task_all(tasks)   \u2192   parallel fan-out to Activity Functions",
      "lineHeight": 1.3
    },
    {
      "id": "dl4",
      "type": "text",
      "x": 88,
      "y": 406,
      "width": 1140,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "text": "\u2464 return synthesize(results)   \u2192   grounded response with source citations",
      "fontSize": 10,
      "fontFamily": 3,
